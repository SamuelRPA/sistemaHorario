# Copia a .env y rellena. No subas .env al repositorio.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sistema_horario"

# Supabase: la URI "Direct" (db.xxx.supabase.co) suele ser solo IPv6; en Windows usa "Session pooler"
# en el panel (Connect → Session pooler) y añade ?sslmode=require al final. Ejemplo de forma:
# DATABASE_URL="postgresql://postgres.TU_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Secreto para firmar JWT (mín. 32 caracteres aleatorios en producción)
JWT_SECRET=

PORT=4000
NODE_ENV=development

# Producción (p. ej. Render): NODE_ENV=production y build del front en ../frontend/dist
# FRONTEND_DIST=/ruta/absoluta/al/dist   (opcional; por defecto ../../frontend/dist desde backend/src)
# Render define RENDER=true; trust proxy se activa solo para rate limit / cookies.

# Orígenes permitidos del frontend (producción). Varios separados por coma.
# CORS_ORIGIN=https://tu-dominio.com
#
# Si el front en desarrollo (p. ej. localhost:3000) llama al API en otro host (Render),
# incluye ese origen en CORS_ORIGIN y activa cookies cross-site:
# CORS_ORIGIN=http://localhost:3000,https://sistemahorario.onrender.com
# COOKIE_CROSS_SITE=1

# Tras un proxy reverso (nginx, etc.): TRUST_PROXY=1
# TRUST_PROXY=1

# Límites de peticiones (opcional)
# RATE_LIMIT_API_MAX=400
# RATE_LIMIT_AUTH_MAX=30

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_FROM=
