# Copia a .env.docker y usa: docker compose --env-file .env.docker up --build
# No subas .env.docker al repositorio.

POSTGRES_USER=sistema
POSTGRES_PASSWORD=sistema_dev
POSTGRES_DB=sistema_horario
POSTGRES_PORT=5432
APP_PORT=4000

# Obligatorio en producción: ≥32 caracteres y no una frase obvia (ver assertProductionSecurity en el backend)
JWT_SECRET=reemplaza_por_32_o_mas_caracteres_aleatorios_seguros

# Opcional: orígenes CORS separados por coma si sirves front y API en dominios distintos
# CORS_ORIGIN=https://tu-dominio.com

# Tras nginx / proxy: TRUST_PROXY=1
# TRUST_PROXY=0

# Correo (recuperación de contraseña); si vacío, esa función fallará con mensaje claro
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_APP_PASSWORD=
# SMTP_FROM=
